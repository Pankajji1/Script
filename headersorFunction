function solveCaptcha($url, $data = [], $json = false)
{
    global $API_KEY, $proxy;

    $result = [
        'time'      => null,
        'attempts'  => 0,
        'value'     => null,
        'response'  => null
    ];

    $data[str_contains($url, "in.php") ? "key" : "api_key"] = $API_KEY;

    // ================= REQUEST =================

    $req = function ($url, $post = null) use ($json, $proxy) {

        $ch = curl_init($url);

        curl_setopt_array($ch, [
            CURLOPT_RETURNTRANSFER => true,
            CURLOPT_FOLLOWLOCATION => true,
            CURLOPT_SSL_VERIFYPEER => false,
            CURLOPT_SSL_VERIFYHOST => false,
            CURLOPT_CONNECTTIMEOUT => 30,
            CURLOPT_TIMEOUT => 60
        ]);

        if ($post !== null) {

            curl_setopt($ch, CURLOPT_POST, true);

            curl_setopt(
                $ch,
                CURLOPT_POSTFIELDS,
                $json
                    ? json_encode($post)
                    : http_build_query($post)
            );
        }

        if ($json) {

            curl_setopt($ch, CURLOPT_HTTPHEADER, [
                "Content-Type: application/json"
            ]);
        }

        if ($proxy) {
            curl_setopt($ch, CURLOPT_PROXY, $proxy);
        }

        $response = curl_exec($ch);
        $error = curl_error($ch);

        curl_close($ch);

        return [
            $response === false ? null : trim($response),
            $error
        ];
    };

    // ================= SEND =================

    [$response, $error] = $req($url, $data);

    if ($error || !$response) {

        $result['time'] = date("h:i:s A");
        $result['value'] = $error ?: "Empty Response";

        return $result;
    }

    // ================= JSON ERROR =================

    $jsonData = json_decode($response, true);

    if (
        isset($jsonData['success']) &&
        $jsonData['success'] === false
    ) {

        slow($jsonData['error'] . "\r");

        $result['time'] = date("h:i:s A");
        $result['value'] = $jsonData['error'];

        return $result;
    }

    // ================= JOB ID =================

    preg_match('/OK\|(\d+)/', $response, $match);

    $jobId = $match[1] ?? null;

    if (!$jobId) {

        $result['time'] = date("h:i:s A");
        $result['value'] = $response;

        return $result;
    }

    slow("JOB ID -> {$jobId}\r");

    // ================= CHECK =================

    while ($result['attempts']++ < 100) {

        sleep(2);

        [$check] = $req(
            "https://bypassallshortlinks.space/res.php?id={$jobId}&key={$API_KEY}"
        );

        if (!$check || str_contains($check, "NOT_READY")) {

            slow(
                "[{$result['attempts']}] Captcha Processing...\r"
            );

            continue;
        }

        // ================= CHECK JSON ERROR =================

        $checkJson = json_decode($check, true);

        if (
            isset($checkJson['success']) &&
            $checkJson['success'] === false
        ) {

            slow($checkJson['error'] . "\r");

            $result['time'] = date("h:i:s A");
            $result['value'] = $checkJson['error'];

            return $result;
        }

        // ================= SUCCESS =================

        $result['time'] = date("h:i:s A");

        // Full Response
        $result['value'] = $check;

        // Clean Response
        $result['response'] = str_replace("OK|", "", $check);

        return $result;
    }

    // ================= TIMEOUT =================

    $result['time'] = date("h:i:s A");
    $result['value'] = "Timeout";

    return $result;
}

